## Django
DEBUG=True
SECRET_KEY=change-me
# ALLOWED_HOSTS=localhost,127.0.0.1,your-vps-ip

## Database (existing / external)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=map_db
DB_USER=map_user
DB_PASSWORD=secure_password
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_SSLMODE=

## JWT
SIGNING_KEY=change-me-too
ACCESS_TOKEN_LIFETIME=480
REFRESH_TOKEN_LIFETIME=600
ROTATE_REFRESH_TOKENS=True
BLACKLIST_AFTER_ROTATION=False
UPDATE_LAST_LOGIN=True

## If you want a local Postgres container:
## - set DB_HOST=db and DB_PORT=5432
## - run: docker compose --profile localdb up --build

## Tunnel (localtunnel): при ENABLE_TUNNEL=1 контейнер поднимает туннель и добавляет его URL в CSRF_TRUSTED_ORIGINS
# ENABLE_TUNNEL=1

## Gunicorn (docker entrypoint)
# GUNICORN_WORKERS=2

## S3 / MinIO (production VPS)
# USE_S3=1
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=change-me
# AWS_ACCESS_KEY_ID=mapapp
# AWS_SECRET_ACCESS_KEY=change-me
# AWS_STORAGE_BUCKET_NAME=map-media
# AWS_S3_ENDPOINT_URL=http://minio:9000
# AWS_S3_REGION_NAME=us-east-1
